{
  "name": "SlothProxyV2 Dev",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22-playwright",
  "remoteUser": "node",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "SlothProxyV2",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "remoteEnv": {
    "SUPABASE_URL": "https://feylgjuuqmqujtlwwfza.supabase.co",
    "SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
    "SUPABASE_SERVICE_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
    "CRON_SECRET": "slothproxy-secret-2025",
    "PORT": "8080",
    "ALLOW_ORIGIN": "*",
    "NODE_ENV": "production",
    "CACHE_TTL_MS": "900000",
    "CACHE_MAX": "500",
    "RATE_PER_MIN": "180",
    "RENDER_TIMEOUT_MS": "15000",
    "NAV_TIMEOUT_MS": "25000",
    "WAIT_UNTIL": "networkidle"
  }
}
